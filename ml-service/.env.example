# The frontend URL for CORS access
# Example for Vercel: https://your-frontend-project.vercel.app
FRONTEND_URL=http://localhost:5173

# Your Gemini API Key from Google AI Studio (Required for fallback features)
GEMINI_API_KEY=YOUR_GEMINI_KEY_HERE

# Your OpenAI API Key (Optional depending on your configuration)
OPENAI_API_KEY=YOUR_OPENAI_KEY_HERE
