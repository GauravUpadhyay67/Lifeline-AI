# Make sure to rename this file to .env in your actual deployments
# and fill in your production backend and ML service URLs.

# The URL of your deployed Node.js backend (e.g. backend service on Render/Railway)
# Example: https://lifeline-backend.onrender.com
VITE_API_URL=http://localhost:5000

# The URL of your deployed Python FastAPI ML Service
# Example: https://lifeline-ml-service.onrender.com
VITE_ML_URL=http://localhost:8000
